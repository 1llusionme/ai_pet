MINDSHADOW_HOST=0.0.0.0
MINDSHADOW_PORT=5001
MINDSHADOW_DB_PATH=/data/mindshadow.db
MINDSHADOW_UPLOAD_DIR=/data/uploads
MINDSHADOW_KB_PATH=/app/server/knowledge_base/teaching_exam_kb.json
MINDSHADOW_LLM_PROVIDER=openai_compatible
MINDSHADOW_LLM_BASE_URL=https://api.openai.com/v1/chat/completions
MINDSHADOW_LLM_MODEL=gpt-4o-mini
MINDSHADOW_LLM_API_KEY=replace_with_real_key
MINDSHADOW_LLM_TIMEOUT_SECONDS=30
MINDSHADOW_LLM_VERIFY_SSL=true
MINDSHADOW_RATE_LIMIT_MAX_REQUESTS_PER_MINUTE=20
MINDSHADOW_OPS_TOKEN=replace_with_secure_ops_token
MINDSHADOW_MEMORY_DEBUG_ENABLED=0
MINDSHADOW_HYBRID_RECALL_ENABLED=1
MINDSHADOW_HYBRID_RECALL_RATIO=0.6
MINDSHADOW_HYBRID_RECALL_WHITELIST=
MINDSHADOW_ENABLE_WEB_SEARCH=true
MINDSHADOW_GUNICORN_WORKERS=2
MINDSHADOW_GUNICORN_THREADS=4
MINDSHADOW_GUNICORN_TIMEOUT=120
MINDSHADOW_GUNICORN_GRACEFUL_TIMEOUT=30
MINDSHADOW_GUNICORN_KEEPALIVE=5
